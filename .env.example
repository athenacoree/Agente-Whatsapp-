# WAHA API Configuration
WAHA_API_URL=http://localhost:3010
WAHA_SESSION_NAME=default
WAHA_API_KEY=your_waha_api_key_here

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Bot Configuration
BOT_COMMAND_KEY=!ai
BOT_NAME=WA Bot

# Server Configuration
PORT=3010

# Development Mode
SIMULATION_MODE=false

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true

# Optional: Monitored Chats (comma-separated chat IDs)
# MONITORED_CHATS=chat1@c.us,chat2@g.us